# ============================================================================
# Smart Todo AI Platform — variables d'environnement
#
# Copie ce fichier en `.env` (à la racine) puis remplis les valeurs.
# Docker Compose lit ce fichier pour la substitution directe (${VAR}) : une
# seule source de vérité pour les URLs et secrets utilisés par la plateforme.
#
# Ne commite jamais le fichier `.env` réel (voir .gitignore).
# ============================================================================

# ----------------------------------------------------------------------------
# Django (backend)
# ----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
# Origines autorisées à appeler l'API depuis un navigateur (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# ----------------------------------------------------------------------------
# Base de données PostgreSQL
# ----------------------------------------------------------------------------
DB_NAME=todo_ai
DB_USER=todo_user
DB_PASSWORD=change-me-to-a-strong-password
# En local (hors Docker) : localhost. En Docker : surchargé à "postgres"
# directement dans docker-compose.yml (nom du service = nom d'hôte réseau).
DB_HOST=localhost
DB_PORT=5432

# ----------------------------------------------------------------------------
# Redis — broker et backend de résultats Celery (tâches en arrière-plan :
# rappels de meetings, transcription/traitement IA, génération de rapports)
# ----------------------------------------------------------------------------
# En local : redis://localhost:6379/0. En Docker : surchargé à
# redis://redis:6379/0 directement dans docker-compose.yml.
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# Kafka — bus d'événements centralisé (réunion démarrée, tâche complétée,
# utilisateur connecté, ...) consommé par les services audio/audit/statistiques
# ----------------------------------------------------------------------------
# En local : localhost:29092. En Docker : surchargé à kafka:9092 directement
# dans docker-compose.yml.
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
# Coupe-circuit : passe à False pour désactiver toute publication/consommation
# d'événements (ex: environnement sans Kafka disponible).
KAFKA_ENABLED=True
KAFKA_EVENTS_TOPIC=smart-todo.events
KAFKA_DEAD_LETTER_TOPIC=smart-todo.events.dlq
KAFKA_TOPIC_PARTITIONS=6

# ----------------------------------------------------------------------------
# Service ML (prédictions TensorFlow/scikit-learn)
# ----------------------------------------------------------------------------
# URL appelée par le backend Django pour les prédictions (temps, retard,
# priorité, risque). En Docker : surchargée à http://ml-service:5001.
ML_SERVICE_URL=http://localhost:5001
# Origines autorisées à appeler directement l'API Flask du service ML (CORS)
CORS_ORIGINS=http://localhost:8000
# Jeton partagé requis pour déclencher un ré-entraînement via POST /train
ML_TRAIN_SECRET=change-me-to-a-shared-training-secret

# ----------------------------------------------------------------------------
# Service Meetings (signaling WebRTC + consommateur Kafka audio)
# ----------------------------------------------------------------------------
PORT=4000
# URL du frontend, utilisée pour la configuration CORS de Socket.IO
FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Intégrations tierces (optionnelles)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
SLACK_BOT_TOKEN=

# ----------------------------------------------------------------------------
# Frontend (React) — variables injectées au démarrage/build (CRA)
# Toute URL appelée par le navigateur doit être une adresse joignable depuis
# la machine de l'utilisateur (jamais un nom de service Docker interne).
# ----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_ML_URL=http://localhost:5001
REACT_APP_MEETING_SERVICE_URL=http://localhost:4000
REACT_APP_WS_URL=ws://localhost:8000
