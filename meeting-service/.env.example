PORT=4000
FRONTEND_URL=http://localhost:3000

# Bus d'événements Kafka — consomme "meeting.started" (topic centralisé) pour
# pré-provisionner la salle WebRTC, totalement découplé du backend Django.
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=smart-todo.events
KAFKA_DLQ_TOPIC=smart-todo.events.dlq
