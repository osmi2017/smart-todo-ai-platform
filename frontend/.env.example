# Variables Create React App — lues au démarrage (npm start) et injectées au
# build. Toute URL ici doit être joignable depuis le navigateur de
# l'utilisateur (jamais un nom de service Docker interne comme "backend").

REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_ML_URL=http://localhost:5001
REACT_APP_MEETING_SERVICE_URL=http://localhost:4000
# Optionnel : par défaut, dérivée automatiquement de l'origine de la page
# (ws:// ou wss:// selon le protocole).
REACT_APP_WS_URL=ws://localhost:8000
