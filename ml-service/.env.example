# URL(s) autorisée(s) à appeler l'API Flask de ce service (CORS)
CORS_ORIGINS=http://localhost:8000

# Jeton partagé requis pour déclencher un ré-entraînement via POST /train
ML_TRAIN_SECRET=change-me-to-a-shared-training-secret

# Bus d'événements Kafka — le consommateur (kafka_consumer.py) réagit à
# "task_completed" pour maintenir des statistiques cumulées, totalement
# découplé du backend Django et du serveur Flask de prédiction.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_EVENTS_ENABLED=true
