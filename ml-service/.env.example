# URL(s) autorisée(s) à appeler l'API Flask de ce service (CORS)
CORS_ORIGINS=http://localhost:8000

# Jeton partagé requis pour déclencher un ré-entraînement via POST /train
ML_TRAIN_SECRET=change-me-to-a-shared-training-secret

# Bus d'événements Kafka — le consommateur (kafka_consumer.py) réagit aux
# événements "task.completed" du topic centralisé pour maintenir des
# statistiques cumulées, totalement découplé du backend Django et du serveur
# Flask de prédiction.
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=smart-todo.events
KAFKA_DLQ_TOPIC=smart-todo.events.dlq
# Emplacement du fichier d'état des statistiques (persisté hors du code source).
KAFKA_STATS_FILE=/app/stats/kafka_stats_state.json
